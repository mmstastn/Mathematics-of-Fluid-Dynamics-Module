<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">vwall:=simplify(diff(phi,y));</Text-field>
</Input>
<Output>
<Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">KigpLCYqJClJInhHNiIiIiMiIiJGKiokKUkieUdGKEYpRipGKiwmKiYjRipGKUYqSSJuR0YoRipGKkYqISIiRipGMUYqLCYqJkYtRiotSSRjb3NHNiQlKnByb3RlY3RlZEdJKF9zeXNsaWJHRig2IyomRjFGKi1JJ2FyY3RhbkdGNzYjKiZGLUYqRidGMkYqRipGKiomLUkkc2luR0Y3RjpGKkYnRipGMkYq</Equation></Text-field>
