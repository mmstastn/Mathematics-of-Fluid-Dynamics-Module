<Group labelreference="L21" drawlabel="true">
<Input>
<Text-field style="Text" size="16" layout="Normal"><Font size="16">After I have defined the velocities from the potential I proceed as in the vortex examples to get Maple to plot the velocity field and some pathlines.</Font></Text-field>
</Input>
</Group>
<Group labelreference="L11">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F3 := proc(N,t,X,XP)                   # First order system
   local rtemp, thetatemp,n: n:=3: rtemp:=sqrt(X[1]*X[1]+X[2]*X[2]): thetatemp:=arctan(X[2]/X[1]): 
   XP[1]:=0.2*n*rtemp^(n/2-1)*(sin(n*thetatemp)*X[2]+cos(n*thetatemp)*X[1]); XP[2] := -n*0.2*rtemp^(n/2-1)*(sin(n*thetatemp)*X[1]-cos(n*thetatemp)*X[2]);
end proc;
DEplot(F3,[x(t),y(t)],t=0..1.8,number=2,[[x(0)=5,y(0)=5*(sqrt(3)-0.01)],[x(0)=5,y(0)=5*(sqrt(3)-0.04)],
[x(0)=5,y(0)=5*(sqrt(3)-0.08)]],stepsize=.02,title=`Path lines Wall Angle Flow`,
color=[.3*y(t)*(x(t)-1),x(t)*(1-y(t)),.1],linecolor=[black,blue,red],arrows=MEDIUM,
method=rkf45,font=[COURIER,16],titlefont=[COURIER,16]);DEplot(F3,x(t),t=0..1.8,number=2,[[x(0)=5,y(0)=5*(sqrt(3)-0.01)],[x(0)=5,y(0)=5*(sqrt(3)-0.04)],
[x(0)=5,y(0)=5*(sqrt(3)-0.08)]],stepsize=.02,title=`Path lines Wall Angle Flow`,
color=[.3*y(t)*(x(t)-1),x(t)*(1-y(t)),.1],linecolor=[black,blue,red],arrows=none,
method=rkf45,font=[COURIER,16],titlefont=[COURIER,16]); vort_wall:=simplify(diff(vwall,x)-diff(uwall,y)); e11_wall:=simplify(subs(n=3,diff(uwall,x))); e12_wall:=simplify(subs(n=3,0.5*(diff(uwall,y)+diff(vwall,x)))); e22_wall:=simplify(subs(n=3,diff(vwall,y))); divu:=simplify(e11_wall+e22_wall);</Text-field>
</Input>
